{
  "name": "hal-search-ssr",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.ts --outDir dist/server"
  },
  "dependencies": {
    "express": "^4.18.2",
    "hal-search": "^0.1.0",
    "jsdom": "^24.0.0",
    "sirv": "^2.0.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsdom": "^21.1.6",
    "@types/node": "^20.11.17",
    "typescript": "^5.2.2",
    "vite": "^5.1.0"
  }
}
